# Copiez ce fichier en .env.local et renseignez vos identifiants AlwaysData.

###> symfony/mailer ###
# Compte email créé dans AlwaysData > E-mails (adresse complète + mot de passe du compte)
MAILER_DSN=smtp://recipeboard@alwaysdata.net:MOT_DE_PASSE@smtp-recipeboard.alwaysdata.net:587
MAILER_FROM=recipeboard@alwaysdata.net
MAILER_FROM_NAME="SPC Formation"
