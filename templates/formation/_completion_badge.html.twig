{# Badge fin de formation — carte épurée Lyceo (web) #}
<div class="lyceo-completion-badge {{ extraClass|default('') }}" role="img" aria-label="Module validé Lyceo Campus">
    <div class="lyceo-completion-badge__shine" aria-hidden="true"></div>
    <div class="lyceo-completion-badge__body">
        <img src="{{ asset('image/lyceo-logo-white.png') }}"
             alt=""
             class="lyceo-completion-badge__logo"
             width="160"
             height="48">
        <div class="lyceo-completion-badge__divider" aria-hidden="true"></div>
        <p class="lyceo-completion-badge__status">
            <i class="bi bi-patch-check-fill" aria-hidden="true"></i>
            Module validé
        </p>
    </div>
    <div class="lyceo-completion-badge__tail" aria-hidden="true"></div>
</div>
