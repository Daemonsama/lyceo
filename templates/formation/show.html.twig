{% extends 'base.html.twig' %}

{% block title %}{{ formation.titre }}{% endblock %}

{% block body %}

    {# Bandeau pleine largeur #}
    <div class="formation-header-fullwidth">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-8">
                    <h1 class="display-4 fw-bold mb-3">{{ formation.titre }}</h1>
                    <div class="d-flex gap-3 mb-3">
                    <span class="badge bg-light text-dark">
                        <i class="bi bi-book"></i> {{ formation.chapitres|length }} chapitres
                    </span>
                        <span class="badge bg-light text-dark">
                        <i class="bi bi-clock"></i> Accès illimité
                    </span>
                    </div>
                </div>
                {% if not app.user.hasFormation(formation) %}
                    <div class="col-lg-4 text-lg-end">
                        <div class="price-badge">{{ formation.prix }}€</div>
                        <p class="mb-0 opacity-75">Prix unique</p>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    <div class="container my-5">

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label == 'danger' ? 'danger' : (label == 'success' ? 'success' : 'info') }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
                </div>
            {% endfor %}
        {% endfor %}

        <div class="row mb-5">

            {# Colonne gauche : vidéo + description #}
            <div class="col-lg-8">

                {# Vidéo de présentation #}
                {% if formation.media %}
                    {% set mediaRaw = formation.media|trim %}
                    {% set mediaLower = mediaRaw|lower %}

                    {% if 'youtube.com' in mediaLower or 'youtu.be' in mediaLower %}
                        {% set youtubeId = '' %}
                        {% if 'watch?v=' in mediaRaw %}
                            {% set youtubeId = mediaRaw|split('watch?v=')|last|split('&')|first %}
                        {% elseif 'youtu.be/' in mediaRaw %}
                            {% set youtubeId = mediaRaw|split('youtu.be/')|last|split('?')|first %}
                        {% elseif 'youtube.com/embed/' in mediaRaw %}
                            {% set youtubeId = mediaRaw|split('youtube.com/embed/')|last|split('?')|first %}
                        {% endif %}
                        <div class="formation-video-wrapper mb-4">
                            <div class="formation-video-badge">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M15 10L19.553 7.724A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                                Vidéo de la formation
                            </div>
                            <h3 class="formation-video-title">Présentation de la formation</h3>
                            <div class="formation-youtube-wrapper">
                                <iframe
                                    src="https://www.youtube.com/embed/{{ youtubeId }}"
                                    title="Vidéo de la formation"
                                    frameborder="0"
                                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                                    allowfullscreen>
                                </iframe>
                            </div>
                        </div>
                    {% elseif mediaLower ends with '.mp4' or mediaLower ends with '.webm' or mediaLower ends with '.ogg' %}
                        <div class="formation-video-wrapper mb-4">
                            <div class="formation-video-badge">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M15 10L19.553 7.724A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                                Vidéo de la formation
                            </div>
                            <h3 class="formation-video-title">Présentation de la formation</h3>
                            <video controls class="formation-video-player">
                                <source src="{{ asset('medias/' ~ mediaRaw) }}">
                                Votre navigateur ne supporte pas la vidéo.
                            </video>
                        </div>
                    {% endif %}
                {% endif %}

                {# Description #}
                <div class="card shadow-sm border-0">
                    <div class="card-body p-4">
                        <h3 class="h4 mb-3">
                            <i class="bi bi-info-circle text-primary"></i> À propos de cette formation
                        </h3>
                        <div class="text-muted">
                            {{ formation.description|raw }}
                        </div>
                    </div>
                </div>
            </div>

            {# Sidebar avec actions #}
            <div class="col-lg-4">
                <div class="card shadow-sm border-0 sticky-top" style="top: 20px;">
                    <div class="card-body p-4">
                        {% if not app.user.hasFormation(formation) %}
                            {% set isStudentChecked = app.flashes('is_student')|first|default('') == '1' %}
                            <h5 class="mb-3">Commencer cette formation</h5>
                            <form id="formation-purchase-form" method="post"
                                  action="{{ path('app_formation_buy', {formation: formation.id}) }}"
                                  class="d-grid gap-2">
                                <input type="hidden" name="_token" value="{{ csrf_token('formation_buy') }}">

                                <div class="form-check mb-1">
                                    <input class="form-check-input" type="checkbox" id="is_student" name="is_student" value="1"
                                           {{ isStudentChecked ? 'checked' : '' }}>
                                    <label class="form-check-label" for="is_student">
                                        Je suis étudiant <span class="text-muted">(−10&nbsp;%)</span>
                                    </label>
                                </div>

                                <div class="text-center py-2 mb-1 border rounded bg-light">
                                    <p class="text-muted small mb-1">Prix de la formation</p>
                                    <p class="h3 mb-0 fw-bold text-primary">
                                        <span id="formation-price-display"
                                              data-base-price="{{ formation.prix }}"
                                              data-student-discount="10">{{ formation.prix|number_format(2, ',', ' ') }}</span>&nbsp;€
                                    </p>
                                    <p class="small text-success mb-0 d-none" id="formation-student-hint">
                                        <i class="bi bi-mortarboard"></i> Tarif étudiant appliqué
                                    </p>
                                </div>

                                <label for="promo_code" class="form-label small text-muted mb-0">Code promo (optionnel)</label>
                                <input type="text" class="form-control" id="promo_code" name="promo_code"
                                       placeholder="Ex. BIENVENUE10" autocomplete="off"
                                       value="{{ app.flashes('promo_code')|first|default('') }}">
                                <button type="submit" class="btn btn-primary btn-lg" id="formation-buy-btn">
                                    <i class="bi bi-cart-plus"></i>
                                    Acheter pour <span id="formation-buy-price">{{ formation.prix|number_format(2, ',', ' ') }}</span>&nbsp;€
                                </button>
                                <a class="btn btn-outline-secondary" href="{{ path('app_formation') }}">
                                    <i class="bi bi-arrow-left"></i> Retour au catalogue
                                </a>
                            </form>
                            <p class="small text-muted mt-2 mb-0">
                                Paiement sécurisé par Stripe. Cochez «&nbsp;Je suis étudiant&nbsp;» pour −10&nbsp;%.
                            </p>
                        {% else %}
                            {% if formationTerminee and formationBadgeAsset %}
                                <div class="text-center mb-3">
                                    <img src="{{ asset(formationBadgeAsset) }}"
                                         alt="Badge de fin de formation"
                                         style="max-width: 180px; width: 100%; height: auto;">
                                </div>
                            {% endif %}
                            <h5 class="mb-3">Accès rapide</h5>
                            <div class="d-grid gap-2">
                                {% if formationTerminee %}
                                    <a class="btn btn-success btn-lg"
                                       href="{{ path('app_formation_attestation', { formation: formation.id }) }}">
                                        <i class="bi bi-download"></i> Télécharger l'attestation (PDF)
                                    </a>
                                {% endif %}
                                <a class="btn btn-primary btn-lg"
                                   href="{{ path('app_suivi_formation', {
                                       'chapitre': chapitreEnCours ? chapitreEnCours.id : formation.chapitres[0].id
                                   }) }}">
                                    <i class="bi bi-play-circle"></i>
                                    {{ formationTerminee ? 'Revoir la formation' : (chapitreEnCours ? 'Reprendre la formation' : 'Commencer la formation') }}
                                </a>
                                <a class="btn btn-outline-secondary" href="{{ path('app_formation') }}">
                                    <i class="bi bi-arrow-left"></i> Catalogue des formations
                                </a>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>

        </div>

        {# Liste des chapitres #}
        <div class="accordion" id="chapitresAccordion">
            {% for chapitre in formation.chapitres %}
                <div class="card chapitre-card mb-3 border-0 shadow-sm
                {{ chapitreEnCours and chapitre.id == chapitreEnCours.id ? 'chapitre-en-cours' : '' }}">
                    <div class="card-header bg-white border-0" id="heading{{ chapitre.id }}">
                        <div class="d-flex align-items-center py-2">
                            <div class="chapter-number me-3">
                                {{ loop.index }}
                            </div>
                            <div class="flex-grow-1">
                                <h5 class="mb-1">
                                    {{ chapitre.titre }}
                                    {% if chapitreEnCours and chapitre.id == chapitreEnCours.id %}
                                        <span class="badge bg-primary ms-2">
                                        <i class="bi bi-star-fill"></i> En cours
                                    </span>
                                    {% endif %}
                                </h5>
                            </div>
                            {% if app.user.hasFormation(formation) %}
                                <a href="{{ path('app_suivi_formation', {'chapitre':chapitre.id}) }}"
                                   class="btn btn-sm {{ chapitreEnCours and chapitre.id == chapitreEnCours.id ? 'btn-primary' : 'btn-outline-primary' }}">
                                    <i class="bi bi-play-circle"></i>
                                    {{ chapitreEnCours and chapitre.id == chapitreEnCours.id ? 'Continuer' : 'Voir' }}
                                </a>
                                {% if chapitre.quiz and chapitre.quiz.questions|length > 0 %}
                                    <span class="badge bg-info text-dark ms-1" title="Quiz disponible pour ce chapitre">
                                        <i class="bi bi-patch-question"></i> Quiz
                                    </span>
                                {% endif %}
                            {% else %}
                                <button class="btn btn-sm btn-outline-secondary" disabled>
                                    <i class="bi bi-lock"></i> Verrouillé
                                </button>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>

        {# Call to action final (uniquement si pas acheté) #}
        {% if not app.user.hasFormation(formation) %}
            <div class="row mt-5">
                <div class="col-12">
                    <div class="card bg-primary text-white border-0 shadow">
                        <div class="card-body text-center p-5">
                            <h3 class="mb-3">Prêt à commencer ?</h3>
                            <p class="mb-4 opacity-75">Accédez immédiatement à tous les chapitres</p>
                            <button type="submit" form="formation-purchase-form"
                                    class="btn btn-light btn-lg px-5" id="formation-cta-buy-btn">
                                Acheter pour <span id="formation-cta-buy-price">{{ formation.prix|number_format(2, ',', ' ') }}</span>&nbsp;€
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}

    </div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {% if not app.user.hasFormation(formation) %}
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                const studentCheckbox = document.getElementById('is_student');
                const priceDisplay = document.getElementById('formation-price-display');
                const buyPrice = document.getElementById('formation-buy-price');
                const ctaBuyPrice = document.getElementById('formation-cta-buy-price');
                const studentHint = document.getElementById('formation-student-hint');
                const headerPriceBadge = document.querySelector('.formation-header-fullwidth .price-badge');

                if (!studentCheckbox || !priceDisplay) {
                    return;
                }

                const basePrice = parseFloat(priceDisplay.dataset.basePrice);
                const discountPercent = parseInt(priceDisplay.dataset.studentDiscount || '10', 10);

                const formatPrice = (value) => value.toLocaleString('fr-FR', {
                    minimumFractionDigits: 2,
                    maximumFractionDigits: 2,
                });

                const updatePrices = () => {
                    const isStudent = studentCheckbox.checked;
                    const finalPrice = isStudent
                        ? Math.round(basePrice * (1 - discountPercent / 100) * 100) / 100
                        : basePrice;
                    const formatted = formatPrice(finalPrice);

                    priceDisplay.textContent = formatted;
                    if (buyPrice) {
                        buyPrice.textContent = formatted;
                    }
                    if (ctaBuyPrice) {
                        ctaBuyPrice.textContent = formatted;
                    }
                    if (headerPriceBadge) {
                        headerPriceBadge.textContent = formatted + '€';
                    }
                    if (studentHint) {
                        studentHint.classList.toggle('d-none', !isStudent);
                    }
                };

                studentCheckbox.addEventListener('change', updatePrices);
                updatePrices();
            });
        </script>
    {% endif %}
{% endblock %}
