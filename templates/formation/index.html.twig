{% extends 'base.html.twig' %}

{% block title %}Catalogue des Formations{% endblock %}

{% block body %}
    <!-- Hero Section -->
    <div class="hero-section">
        <div class="hero-content">
            <div class="container">
                <div class="row justify-content-center text-center">
                    <div class="col-lg-8">
                        <h1 class="display-4 fw-bold d-inline-flex align-items-center justify-content-center flex-wrap hero-banner-title">
                            <img src="{{ asset('image/logo2-transparent.png') }}" alt="Logo Lyceo Campus" class="hero-banner-logo">
                            Catalogue de Formations
                        </h1>
                        <p class="lead mb-0">
                            Découvrez nos formations en ligne pour développer vos compétences professionnelles
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container">
        <!-- Barre de recherche -->
        <div class="search-container mt-2 mb-5">
            {{ form_start(rechercheForm, {'attr': {'class': 'row g-3 align-items-end'}}) }}
            <div class="col-12 mb-3">
                <h5 class="mb-0">
                    <i class="bi bi-funnel-fill me-2 text-primary"></i>
                    Filtrer les formations
                </h5>
            </div>

            <div class="col-md-10">
                {{ form_row(rechercheForm.categorie, {
                    'label': 'Catégorie',
                    'attr': {'class': 'form-select'}
                }) }}
            </div>

            <div class="col-md-2">
                {{ form_row(rechercheForm.recherche, {
                    'label': false,
                    'attr': {
                        'class': 'btn btn-primary w-100'
                    },
                    'label_html': true,
                    'label': '<i class="bi bi-search me-1"></i> Rechercher'
                }) }}
            </div>
            {{ form_end(rechercheForm) }}
        </div>



        <!-- Titre section + compteur -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="h4 mb-0">
                <i class="bi bi-grid-3x3-gap-fill text-primary me-2"></i>
                Toutes les formations
            </h2>
            <span class="badge bg-primary rounded-pill px-3 py-2">
            {{ formations|length }} formation{{ formations|length > 1 ? 's' : '' }}
        </span>
        </div>

        <!-- Grille de formations -->
        {% if formations|length > 0 %}
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mb-5">
                {% for formation in formations %}
                    <div class="col">
                        <div class="formation-card card h-100">
                            <!-- Image avec zoom au hover -->
                            <div style="overflow: hidden; border-radius: 15px 15px 0 0;">
                                <img src="{{ formation_apercu_url(formation) }}"
                                     class="card-img-top"
                                     alt="Aperçu — {{ formation.titre }}">
                            </div>

                            <div class="card-body">
                                <!-- Titre -->
                                <h5 class="card-title">{{ formation.titre }}</h5>

                                <!-- Description -->
                                <p class="card-text">{{ formation.description|striptags|raw }}</p>

                                <!-- Badge nombre de chapitres -->
                                <div class="mb-3">
                                <span class="badge-chapters">
                                    <i class="bi bi-list-ul me-1"></i>
                                    {{ formation.chapitres|length }} chapitre{{ formation.chapitres|length > 1 ? 's' : '' }}
                                </span>
                                </div>

                                <!-- Footer avec prix et bouton -->
                                <div class="d-flex justify-content-between align-items-center mt-auto pt-3 border-top">
                                <span class="price-tag">
                                    {{ formation.prix }}€
                                </span>
                                    <a href="{{ path('app_formation_show', {'formation': formation.id}) }}"
                                       class="btn btn-details">
                                        Découvrir
                                        <i class="bi bi-arrow-right-circle ms-1"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <!-- État vide -->
            <div class="empty-state">
                <i class="bi bi-inbox"></i>
                <h3>Aucune formation trouvée</h3>
                <p class="text-muted mb-4">
                    Aucune formation ne correspond à vos critères de recherche.
                </p>
                <a href="{{ path('app_formation') }}" class="btn btn-primary btn-lg">
                    <i class="bi bi-arrow-left me-2"></i>
                    Réinitialiser les filtres
                </a>
            </div>
        {% endif %}
    </div>
{% endblock %}
