{% extends 'base.admin.html.twig' %}

{% block title %}{{ formation.titre }}{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item"><a href="{{ path('app_admin_formation_index') }}">Formations</a></li>
    <li class="breadcrumb-item active" aria-current="page">{{ formation.titre }}</li>
{% endblock %}

{% block body %}
    <div class="container py-4">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
            <div class="d-flex align-items-start gap-3">
                <img src="{{ formation_apercu_url(formation) }}"
                     alt=""
                     class="admin-formation-thumb admin-formation-thumb--lg"
                     width="72"
                     height="72">
                <div>
                    <h1 class="h3 mb-1">{{ formation.titre }}</h1>
                    <p class="text-muted mb-0">Formation #{{ formation.id }}</p>
                </div>
            </div>
            <div class="d-flex flex-wrap gap-2">
                <a href="{{ path('app_admin_formation_index') }}" class="btn btn-admin-outline">
                    <i class="bi bi-arrow-left me-1"></i> Retour
                </a>
                <a href="{{ path('app_admin_formation_edit', { formation: formation.id }) }}" class="btn btn-admin-primary">
                    <i class="bi bi-pencil me-1"></i> Modifier
                </a>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm admin-user-card">
                    <div class="card-body p-4">
                        <h2 class="h6 text-muted text-uppercase mb-3">Description</h2>
                        <div class="admin-rich-content">
                            {{ formation.description|raw }}
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm admin-user-card h-100">
                    <div class="card-body p-4">
                        <h2 class="h6 text-muted text-uppercase mb-3">Informations</h2>
                        <dl class="row mb-0">
                            <dt class="col-5 text-muted">Prix</dt>
                            <dd class="col-7 fw-bold">{{ formation.prix|number_format(2, ',', ' ') }} €</dd>
                            <dt class="col-5 text-muted">Catégorie</dt>
                            <dd class="col-7">{{ formation.categorie ? formation.categorie.nom : '—' }}</dd>
                            <dt class="col-5 text-muted">Chapitres</dt>
                            <dd class="col-7">{{ formation.chapitres|length }}</dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm admin-user-card">
            <div class="card-header bg-white border-0 pt-4 px-4 pb-0">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                    <div>
                        <h2 class="h5 mb-1">Chapitres</h2>
                        <p class="text-muted small mb-0">Contenu de la formation</p>
                    </div>
                    <a href="{{ path('app_admin_chapitre_new', { formation: formation.id }) }}" class="btn btn-sm btn-admin-primary">
                        <i class="bi bi-plus-lg me-1"></i> Nouveau chapitre
                    </a>
                </div>
            </div>
            <div class="card-body p-0">
                {% if formation.chapitres is not empty %}
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0 admin-user-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Titre</th>
                                    <th>Contenu</th>
                                    <th>Média</th>
                                    <th>Ordre</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                            {% for chapitre in formation.chapitres %}
                                <tr>
                                    <td class="text-muted">{{ chapitre.id }}</td>
                                    <td><strong>{{ chapitre.titre }}</strong></td>
                                    <td class="text-muted small admin-formation-excerpt">
                                        {% set excerpt = chapitre.contenu|striptags %}
                                        {{ excerpt|length > 80 ? excerpt|slice(0, 80) ~ '…' : excerpt }}
                                    </td>
                                    <td>
                                        {% set preview = mediaHelper.resolve(chapitre) %}
                                        {% if preview %}
                                            {% if preview.kind == 'upload_image' %}
                                                <img src="{{ asset(preview.src) }}" width="64" class="rounded" alt="">
                                            {% else %}
                                                <span class="badge bg-admin-standard"><i class="bi bi-play-circle"></i> Vidéo</span>
                                            {% endif %}
                                        {% else %}
                                            <span class="text-muted">—</span>
                                        {% endif %}
                                    </td>
                                    <td>{{ chapitre.ordre }}</td>
                                    <td class="text-end">
                                        <div class="d-inline-flex flex-wrap gap-2 justify-content-end">
                                            <a href="{{ path('app_admin_chapitre_edit', { chapitre: chapitre.id }) }}"
                                               class="btn btn-sm btn-admin-primary">
                                                <i class="bi bi-pencil"></i> Modifier
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <div class="text-center text-muted py-5">
                        Aucun chapitre pour cette formation.
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}
