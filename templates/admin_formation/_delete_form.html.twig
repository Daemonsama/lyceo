<form method="post" action="{{ path('app_admin_formation_delete', {'formation': formation.id}) }}" onsubmit="return confirm('Supprimer cette formation ?\n\nTous les chapitres, quiz et inscriptions associés seront également supprimés.');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ formation.id) }}">
    <button class="btn btn-danger">Supprimer</button>
</form>
