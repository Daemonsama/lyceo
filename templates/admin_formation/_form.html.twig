{% form_theme form 'bootstrap_5_layout.html.twig' %}

{{ form_start(form, { attr: { enctype: 'multipart/form-data' } }) }}
    {{ form_row(form.titre) }}
    {{ form_row(form.description) }}
    {{ form_row(form.prix) }}
    {{ form_row(form.categorie) }}

    <div class="card mb-3">
        <div class="card-header fw-semibold">Aperçu (catalogue)</div>
        <div class="card-body">
            {% if formation is defined and formation.id %}
                <div class="mb-3">
                    <p class="text-muted small mb-2">Aperçu actuel :</p>
                    <img src="{{ formation_apercu_url(formation) }}"
                         alt="Aperçu {{ formation.titre }}"
                         class="img-fluid rounded border"
                         style="max-height: 180px; object-fit: cover;">
                    {% if formation.hasApercu %}
                        <p class="small text-success mt-2 mb-0"><i class="bi bi-check-circle"></i> Image personnalisée</p>
                    {% else %}
                        <p class="small text-muted mt-2 mb-0"><i class="bi bi-image"></i> Image par défaut du site</p>
                    {% endif %}
                </div>
                {% if formation.hasApercu %}
                    {{ form_row(form.removeApercu) }}
                {% endif %}
            {% else %}
                <p class="text-muted small">Sans image, l'aperçu par défaut du catalogue sera utilisé.</p>
            {% endif %}
            {{ form_row(form.apercuFile) }}
        </div>
    </div>

    {{ form_row(form.media) }}

    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-tag"></i> Codes promo</span>
            <button type="button" class="btn btn-sm btn-outline-primary" id="add-promo-code">
                <i class="bi bi-plus-lg"></i> Ajouter un code
            </button>
        </div>
        <div class="card-body">
            <p class="small text-muted mb-3">
                Ajoutez des codes réservés à cette formation (ex. <code>LYCEO10</code>).
                Renseignez <strong>soit</strong> un pourcentage <strong>soit</strong> un montant en euros.
                La <strong>durée</strong> indique le nombre de jours de validité à partir de la création du code (laissez vide pour un code sans expiration).
                Ils seront créés dans Stripe à l'enregistrement.
            </p>

            <div id="promo-codes-list"
                 data-index="{{ form.promoCodes|length }}"
                 data-prototype="{{ form_widget(form.promoCodes.vars.prototype)|e('html_attr') }}">
                {% for promoForm in form.promoCodes %}
                    <div class="promo-code-item border rounded p-3 mb-3 bg-white">
                        <div class="row g-2 align-items-end">
                            <div class="col-md-2">{{ form_row(promoForm.code) }}</div>
                            <div class="col-md-2">{{ form_row(promoForm.discountPercent) }}</div>
                            <div class="col-md-2">{{ form_row(promoForm.discountAmount) }}</div>
                            <div class="col-md-2">{{ form_row(promoForm.validityDays) }}</div>
                            <div class="col-md-2">{{ form_row(promoForm.active) }}</div>
                            <div class="col-md-2">
                                <button type="button" class="btn btn-outline-danger btn-sm w-100 remove-promo-code">
                                    <i class="bi bi-trash"></i> Supprimer
                                </button>
                            </div>
                        </div>
                    </div>
                {% else %}
                    <p class="text-muted mb-0" id="no-promo-codes-msg">
                        Aucun code pour l'instant. Cliquez sur « Ajouter un code ».
                    </p>
                {% endfor %}
            </div>
        </div>
    </div>

    <button class="btn btn-success">{{ button_label|default('Sauvegarder') }}</button>
{{ form_end(form) }}

<script>
    (function () {
        const initPromoCodesCollection = () => {
            const list = document.getElementById('promo-codes-list');
            const addBtn = document.getElementById('add-promo-code');
            if (!list || !addBtn || list.dataset.promoBound === '1') {
                return;
            }
            list.dataset.promoBound = '1';

            const emptyMsg = document.getElementById('no-promo-codes-msg');
            const prototype = list.dataset.prototype || '';

            const refreshEmptyState = () => {
                if (!emptyMsg) {
                    return;
                }
                emptyMsg.style.display = list.querySelectorAll('.promo-code-item').length ? 'none' : 'block';
            };

            const reindexPromoCodes = () => {
                list.querySelectorAll('.promo-code-item').forEach((item, index) => {
                    item.querySelectorAll('[name]').forEach((field) => {
                        field.name = field.name.replace(/\[promoCodes\]\[\d+\]/, `[promoCodes][${index}]`);
                    });
                    item.querySelectorAll('[id]').forEach((field) => {
                        if (field.id.includes('promoCodes')) {
                            field.id = field.id.replace(/_promoCodes_\d+/, `_promoCodes_${index}`);
                        }
                    });
                    item.querySelectorAll('label[for]').forEach((label) => {
                        label.htmlFor = label.htmlFor.replace(/_promoCodes_\d+/, `_promoCodes_${index}`);
                    });
                });
                list.dataset.index = String(list.querySelectorAll('.promo-code-item').length);
                refreshEmptyState();
            };

            const buildPromoRow = (index) => {
                const item = document.createElement('div');
                item.className = 'promo-code-item border rounded p-3 mb-3 bg-white';
                item.innerHTML =
                    '<div class="row g-2 align-items-end">'
                    + '<div class="col-md-2 promo-field-code"></div>'
                    + '<div class="col-md-2 promo-field-percent"></div>'
                    + '<div class="col-md-2 promo-field-amount"></div>'
                    + '<div class="col-md-2 promo-field-validity"></div>'
                    + '<div class="col-md-2 promo-field-active"></div>'
                    + '<div class="col-md-2">'
                    + '<button type="button" class="btn btn-outline-danger btn-sm w-100 remove-promo-code">'
                    + '<i class="bi bi-trash"></i> Supprimer'
                    + '</button>'
                    + '</div>'
                    + '</div>';

                const temp = document.createElement('div');
                temp.innerHTML = prototype.replace(/__name__/g, String(index));
                const groups = temp.querySelectorAll('.mb-3, .form-check');
                const slots = [
                    item.querySelector('.promo-field-code'),
                    item.querySelector('.promo-field-percent'),
                    item.querySelector('.promo-field-amount'),
                    item.querySelector('.promo-field-validity'),
                    item.querySelector('.promo-field-active'),
                ];
                if (groups.length >= 5) {
                    groups.forEach((group, i) => {
                        if (slots[i]) {
                            slots[i].appendChild(group);
                        }
                    });
                } else {
                    item.innerHTML =
                        '<div class="row g-2 align-items-end">'
                        + '<div class="col-12">' + prototype.replace(/__name__/g, String(index)) + '</div>'
                        + '<div class="col-12">'
                        + '<button type="button" class="btn btn-outline-danger btn-sm remove-promo-code">'
                        + '<i class="bi bi-trash"></i> Supprimer'
                        + '</button>'
                        + '</div>'
                        + '</div>';
                }

                return item;
            };

            addBtn.addEventListener('click', () => {
                const index = parseInt(list.dataset.index, 10) || 0;
                list.appendChild(buildPromoRow(index));
                list.dataset.index = String(index + 1);
                refreshEmptyState();
            });

            list.addEventListener('click', (event) => {
                const btn = event.target.closest('.remove-promo-code');
                if (!btn) {
                    return;
                }
                btn.closest('.promo-code-item')?.remove();
                reindexPromoCodes();
            });

            reindexPromoCodes();
        };

        document.addEventListener('DOMContentLoaded', initPromoCodesCollection);
    })();
</script>
