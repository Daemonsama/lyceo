{% extends 'base.html.twig' %}

{% block title %}{{ quiz.titre }} – {{ formation.titre }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/quiz.css') }}">
{% endblock %}

{% block body %}
    <div class="container my-5 quiz-page">
        <h1 class="text-center mb-2">{{ quiz.titre }}</h1>
        <p class="text-center text-muted mb-4">
            Après le chapitre « {{ chapitre.titre }} » — Score minimum : {{ quiz.seuilReussite }}%
        </p>

        {% if quizSubmitted %}
            <div class="alert {{ passed ? 'alert-success' : 'alert-danger' }} text-center mb-4" role="alert">
                {% if passed %}
                    <strong>Quiz réussi !</strong> Votre score : {{ score }}%
                {% else %}
                    <strong>Score insuffisant :</strong> {{ score }}% (minimum {{ quiz.seuilReussite }}%)
                    {% if showReveal %}
                        <br><span class="small">Les bonnes réponses sont affichées en vert. Vous pouvez passer au chapitre suivant.</span>
                    {% else %}
                        <br><span class="small">Tentative {{ failedAttempts }} / {{ maxAttemptsBeforeReveal }} avant affichage des corrections.</span>
                    {% endif %}
                {% endif %}
            </div>
        {% endif %}

        <form method="post" class="card shadow-sm quiz-form {{ quizSubmitted ? 'quiz-form--submitted' : '' }}">
            <input type="hidden" name="_token" value="{{ csrf_token('quiz' ~ quiz.id) }}">

            <div class="card-body px-4 py-4">
                {% for question in quiz.questions %}
                    <fieldset class="mb-4 pb-4 {% if not loop.last %}border-bottom{% endif %}" {% if quizSubmitted %}disabled{% endif %}>
                        <legend class="fs-5 fw-semibold mb-3">
                            {{ loop.index }}. {{ question.enonce }}
                        </legend>
                        {% for reponse in question.reponses %}
                            {% if reponse.libelle|trim is not empty %}
                                {% set state = reponseStates[reponse.id] ?? null %}
                                {% set isChecked = (submittedAnswers[question.id] ?? submittedAnswers[question.id ~ ''] ?? null) == reponse.id %}
                                <div class="form-check mb-2 quiz-answer {{ state ? 'quiz-answer--' ~ state : '' }}">
                                    <input
                                        class="form-check-input"
                                        type="radio"
                                        name="reponses[{{ question.id }}]"
                                        id="q{{ question.id }}_r{{ reponse.id }}"
                                        value="{{ reponse.id }}"
                                        {% if quizSubmitted %}
                                            disabled
                                            {% if isChecked %}checked{% endif %}
                                        {% else %}
                                            required
                                        {% endif %}
                                    >
                                    <label class="form-check-label" for="q{{ question.id }}_r{{ reponse.id }}">
                                        {{ reponse.libelle }}
                                        {% if quizSubmitted and state == 'success' %}
                                            <i class="bi bi-check-circle-fill ms-1"></i>
                                        {% elseif quizSubmitted and state == 'danger' %}
                                            <i class="bi bi-x-circle-fill ms-1"></i>
                                        {% endif %}
                                    </label>
                                </div>
                            {% endif %}
                        {% endfor %}
                    </fieldset>
                {% endfor %}
            </div>

            <div class="card-footer d-flex justify-content-between align-items-center flex-wrap gap-2 bg-white">
                <a href="{{ path('app_suivi_formation', {chapitre: chapitre.id}) }}" class="btn btn-outline-secondary">
                    ← Revoir le chapitre
                </a>

                {% if quizSubmitted %}
                    {% if passed %}
                        <a href="{{ path('app_formation_chap_suivant', {chapitre: chapitre.id}) }}" class="btn btn-success btn-lg">
                            Continuer <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    {% elseif canSkipToNextChapter %}
                        <a href="{{ path('app_formation_chap_suivant', {chapitre: chapitre.id}) }}" class="btn btn-success btn-lg">
                            Passer au chapitre suivant <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    {% else %}
                        <a href="{{ path('app_quiz_formation', {chapitre: chapitre.id}) }}" class="btn btn-primary btn-lg">
                            Réessayer le quiz
                        </a>
                    {% endif %}
                {% elseif canSkipToNextChapter %}
                    <a href="{{ path('app_formation_chap_suivant', {chapitre: chapitre.id}) }}" class="btn btn-success btn-lg">
                        Passer au chapitre suivant <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                {% else %}
                    <button type="submit" class="btn btn-primary btn-lg">
                        Valider le quiz
                    </button>
                {% endif %}
            </div>
        </form>

        {% if quizSubmitted and not passed and not showReveal %}
            <p class="text-center text-muted small mt-3 mb-0">
                <i class="bi bi-info-circle"></i>
                Les réponses que vous avez cochées apparaissent en vert si elles sont correctes, en rouge sinon.
            </p>
        {% endif %}
    </div>
{% endblock %}
