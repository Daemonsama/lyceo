{% extends 'base.html.twig' %}

{% block title %}Email envoyé — Lyceo Campus{% endblock %}

{% block body %}
    <div class="login-page">
        <div class="container">
            <div class="row justify-content-center align-items-center min-vh-100 py-5">
                <div class="col-12 col-md-8 col-lg-6">
                    <div class="card shadow-lg border-0 rounded-4">
                        <div class="card-body p-5 text-center">
                            <div class="logo-icon mb-3">
                                <i class="bi bi-envelope-check-fill"></i>
                            </div>
                            <h2 class="login-title mb-3">Vérifiez votre boîte mail</h2>
                            <p class="text-muted">
                                Si un compte correspond à cette adresse, un email vient d'être envoyé avec un lien
                                pour réinitialiser votre mot de passe.
                            </p>
                            <p class="text-muted">
                                Ce lien expire dans
                                {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle', 'fr') }}.
                            </p>
                            <p class="text-muted small">
                                Pensez à vérifier vos spams ou
                                <a href="{{ path('app_forgot_password_request') }}">réessayez</a>.
                            </p>
                            <a href="{{ path('app_login') }}" class="btn btn-login mt-3">
                                <i class="bi bi-box-arrow-in-right me-2"></i>Retour à la connexion
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
