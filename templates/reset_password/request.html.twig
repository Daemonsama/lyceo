{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié — Lyceo Campus Numérique{% endblock %}

{% block meta_robots %}noindex, nofollow{% endblock %}

{% block body %}
    <div class="login-page">
        <div class="container">
            <div class="row justify-content-center align-items-center min-vh-100 py-5">
                <div class="col-12 col-md-8 col-lg-5">
                    <div class="card shadow-lg border-0 rounded-4">
                        <div class="card-body p-5">
                            <div class="text-center mb-4">
                                <div class="logo-icon mb-3">
                                    <i class="bi bi-key-fill"></i>
                                </div>
                                <h2 class="login-title">Mot de passe oublié</h2>
                                <p class="text-muted mb-0">
                                    Saisissez votre email pour recevoir un lien de réinitialisation.
                                </p>
                            </div>

                            {% for flash_error in app.flashes('reset_password_error') %}
                                <div class="alert alert-danger alert-custom" role="alert">
                                    <i class="bi bi-exclamation-triangle-fill me-2"></i>{{ flash_error }}
                                </div>
                            {% endfor %}

                            {{ form_start(requestForm, { attr: { class: 'login-form' } }) }}
                                <div class="form-floating mb-4">
                                    {{ form_widget(requestForm.email) }}
                                    <label for="{{ requestForm.email.vars.id }}">
                                        <i class="bi bi-envelope me-2"></i>Adresse email
                                    </label>
                                    {{ form_errors(requestForm.email) }}
                                </div>

                                <button class="btn btn-login w-100 py-3 mb-3" type="submit">
                                    <i class="bi bi-send me-2"></i>Envoyer le lien
                                </button>
                            {{ form_end(requestForm) }}

                            <div class="text-center">
                                <a href="{{ path('app_login') }}" class="text-decoration-none">
                                    <i class="bi bi-arrow-left me-1"></i>Retour à la connexion
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
