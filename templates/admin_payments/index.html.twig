{% extends 'base.admin.html.twig' %}

{% block title %}Paiements{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item active" aria-current="page">Paiements</li>
{% endblock %}

{% block body %}
    <div class="container py-4">
        <div class="mb-4">
            <h1 class="h3 mb-1"><i class="bi bi-credit-card"></i> Paiements</h1>
            <p class="text-muted mb-0">Historique de tous les achats enregistrés sur la plateforme.</p>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-6 col-xl-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <p class="text-muted small mb-1">Chiffre d'affaires total</p>
                        <p class="h4 mb-0 text-success">{{ stats.totalRevenue|number_format(2, ',', ' ') }} €</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <p class="text-muted small mb-1">Paiements enregistrés</p>
                        <p class="h4 mb-0">{{ stats.totalCount }}</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <p class="text-muted small mb-1">Ce mois-ci</p>
                        <p class="h4 mb-0">{{ stats.monthRevenue|number_format(2, ',', ' ') }} €</p>
                        <p class="small text-muted mb-0">{{ stats.monthCount }} vente(s)</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <p class="text-muted small mb-1">Via Stripe</p>
                        <p class="h4 mb-0">{{ stats.stripeCount }}</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h2 class="h5 mb-0">Historique des paiements</h2>
            </div>
            <div class="card-body p-0">
                {% if payments is not empty %}
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Date</th>
                                    <th>Client</th>
                                    <th>Module</th>
                                    <th>Montant</th>
                                    <th>Mode</th>
                                    <th>Statut</th>
                                </tr>
                            </thead>
                            <tbody>
                            {% for payment in payments %}
                                <tr>
                                    <td>{{ payment.dateAchat|date('d/m/Y') }}</td>
                                    <td>
                                        <strong>{{ payment.user.prenom }} {{ payment.user.nom }}</strong><br>
                                        <span class="small text-muted">{{ payment.user.email }}</span>
                                    </td>
                                    <td>{{ payment.formation.titre }}</td>
                                    <td><strong>{{ payment.montant|number_format(2, ',', ' ') }} €</strong></td>
                                    <td>
                                        {% if payment.modePaiement == 'stripe' %}
                                            <span class="badge bg-primary">Stripe</span>
                                        {% elseif payment.modePaiement %}
                                            <span class="badge bg-secondary">{{ payment.modePaiement }}</span>
                                        {% else %}
                                            <span class="badge bg-light text-dark">—</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if payment.statut == 'paye' %}
                                            <span class="badge bg-success">Payé</span>
                                        {% elseif payment.statut %}
                                            <span class="badge bg-warning text-dark">{{ payment.statut }}</span>
                                        {% else %}
                                            <span class="badge bg-light text-dark">Enregistré</span>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <div class="p-4 text-center text-muted">
                        <i class="bi bi-inbox display-6 d-block mb-2"></i>
                        Aucun paiement enregistré pour le moment.
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}
