{# templates/home/index.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}Accueil - Stéphane Palmier Consulting{% endblock %}

{% block body %}
    <style>
        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        .feature-card {
            transition: all 0.3s ease;
        }
        .feature-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 10px 30px rgba(102, 126, 234, 0.2) !important;
        }
        .cta-button {
            transition: all 0.3s ease;
        }
        .cta-button:hover {
            transform: scale(1.05);
            box-shadow: 0 10px 30px rgba(102, 126, 234, 0.4);
        }
        .stats-number {
            font-size: 3rem;
            font-weight: bold;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
    </style>

    {# Hero Section #}
    <div class="py-5 text-white position-relative overflow-hidden" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
        <div class="container py-5">
            <div class="row align-items-center">
                <div class="col-lg-7">
                    <h1 class="display-3 fw-bold mb-4">{{ home.heroTitlePrefix }} <span style="text-decoration: underline; text-decoration-color: rgba(255,255,255,0.5);">{{ home.heroTitleHighlight }}</span></h1>
                    <div class="lead mb-4">{{ home.heroLead|raw }}</div>
                    <div class="d-flex gap-3 flex-wrap">
                        <a href="/formation" class="btn btn-light btn-lg px-5 cta-button" style="color: #667eea; font-weight: 600;">
                            <i class="bi bi-rocket-takeoff"></i> Découvrir les formations
                        </a>
                        <a href="#contact" class="btn btn-outline-light btn-lg px-5">
                            <i class="bi bi-envelope"></i> Nous contacter
                        </a>
                    </div>
                </div>
                <div class="col-lg-5 text-center mt-5 mt-lg-0">
                    <div class="p-5">
                        <i class="bi bi-mortarboard display-1 mb-3" style="font-size: 8rem; opacity: 0.9;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Points Clés #}
    <div class="container my-5 py-5">
        <div class="row g-4">
            <div class="col-md-3 col-6 text-center">
                <div class="stats-number">25+</div>
                <p class="text-muted fw-bold">Années d'expérience</p>
            </div>
            <div class="col-md-3 col-6 text-center">
                <div class="stats-number">100%</div>
                <p class="text-muted fw-bold">Formations interactives</p>
            </div>
            <div class="col-md-3 col-6 text-center">
                <div class="stats-number"><i class="bi bi-star-fill" style="color: #667eea;"></i></div>
                <p class="text-muted fw-bold">Coach certifié</p>
            </div>
            <div class="col-md-3 col-6 text-center">
                <div class="stats-number"><i class="bi bi-geo-alt-fill" style="color: #667eea;"></i></div>
                <p class="text-muted fw-bold">Aurillac (15)</p>
            </div>
        </div>
    </div>

    {# Notre Mission #}
    <div class="py-5" style="background: linear-gradient(135deg, #667eea15 0%, #764ba215 100%);">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6 mb-4 mb-lg-0">
                    <h2 class="h1 fw-bold mb-4">Notre mission</h2>
                    <p class="lead mb-4">Vous accompagner dans le développement de votre <strong>AGILITÉ</strong>, votre <strong>CARE</strong>, votre <strong>FLOW</strong> et votre <strong>ENGAGEMENT</strong>.</p>
                    <p class="text-muted">Nous vous délivrons les outils nécessaires pour repenser et déployer votre mission en tant que <strong>coach manager</strong> ou membre d'équipe. Apprenez à communiquer efficacement, maîtrisez la gestion hybride et créez de la valeur partagée.</p>
                </div>
                <div class="col-lg-6">
                    <div class="card shadow-sm border-0 p-4">
                        <h3 class="h5 mb-4" style="color: #667eea;">
                            <i class="bi bi-bullseye"></i> Nos objectifs
                        </h3>
                        <ul class="list-unstyled mb-0">
                            <li class="mb-3 d-flex align-items-start">
                                <i class="bi bi-check-circle-fill me-3 mt-1" style="color: #28a745; font-size: 1.25rem;"></i>
                                <span>Développer votre efficacité professionnelle</span>
                            </li>
                            <li class="mb-3 d-flex align-items-start">
                                <i class="bi bi-check-circle-fill me-3 mt-1" style="color: #28a745; font-size: 1.25rem;"></i>
                                <span>Révéler votre talent unique et votre potentiel</span>
                            </li>
                            <li class="mb-3 d-flex align-items-start">
                                <i class="bi bi-check-circle-fill me-3 mt-1" style="color: #28a745; font-size: 1.25rem;"></i>
                                <span>Accompagner votre équipe vers l'excellence</span>
                            </li>
                            <li class="d-flex align-items-start">
                                <i class="bi bi-check-circle-fill me-3 mt-1" style="color: #28a745; font-size: 1.25rem;"></i>
                                <span>Créer de la valeur partagée dans votre entreprise</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Pour Qui ? #}
    <div class="container my-5 py-5" id="formations">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold mb-3">Pour qui ?</h2>
            <p class="lead text-muted">Nos formations s'adressent aux équipes et managers qui veulent progresser</p>
        </div>

        <div class="row g-4">
            <div class="col-md-6">
                <div class="card shadow-sm border-0 p-4 h-100 feature-card">
                    <div class="d-flex align-items-start gap-3 mb-3">
                        <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; width: 60px; height: 60px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                            <i class="bi bi-building" style="font-size: 1.75rem;"></i>
                        </div>
                        <div>
                            <h3 class="h5 mb-2">Formation INTRA</h3>
                            <p class="text-muted mb-0">Pour votre équipe ou vos managers de différents services au sein de votre entreprise.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card shadow-sm border-0 p-4 h-100 feature-card">
                    <div class="d-flex align-items-start gap-3 mb-3">
                        <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; width: 60px; height: 60px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                            <i class="bi bi-people" style="font-size: 1.75rem;"></i>
                        </div>
                        <div>
                            <h3 class="h5 mb-2">Formation INTER</h3>
                            <p class="text-muted mb-0">Pour managers et équipes de différentes entreprises qui veulent partager leurs expériences.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {% if promoPlayer is not null %}
        <div class="text-center mt-5">
            <div class="card shadow-sm border-0 overflow-hidden"
                 style="background: linear-gradient(135deg, #667eea15 0%, #764ba215 100%);
                    border-left: 4px solid #667eea !important;">
                <div class="p-4 pb-2">
                    <h3 class="h4 fw-bold mb-2" style="color: #667eea;">{{ promo.sectionTitle }}</h3>
                    {% if promo.sectionLead|trim != '' %}
                        <p class="text-muted mb-0">{{ promo.sectionLead|nl2br }}</p>
                    {% endif %}
                </div>
                <div class="px-3 pb-3">
                    <div class="ratio ratio-16x9 mx-auto" style="max-width: 920px;">
                        {% if promoPlayer.kind == 'upload' %}
                            <video controls playsinline preload="metadata" class="w-100 h-100 rounded bg-dark" style="object-fit: contain;">
                                <source src="{{ asset(promoPlayer.src) }}">
                            </video>
                        {% elseif promoPlayer.kind == 'linkedin' %}
                            {# LinkedIn refuse souvent l’iframe (localhost / domaines non autorisés) — lien externe fiable #}
                            <div class="w-100 h-100 d-flex flex-column align-items-center justify-content-center rounded bg-light border p-4 text-center">
                                <i class="bi bi-linkedin display-4 text-primary mb-2"></i>
                                <p class="text-muted small mb-3 px-2">
                                    La vidéo se lit sur LinkedIn (lecture intégrée souvent bloquée par leur sécurité).
                                </p>
                                <a href="{{ promoPlayer.href }}" target="_blank" rel="noopener noreferrer"
                                   class="btn btn-primary btn-lg">
                                    <i class="bi bi-box-arrow-up-right"></i> Voir sur LinkedIn
                                </a>
                            </div>
                        {% elseif promoPlayer.kind == 'youtube' or promoPlayer.kind == 'vimeo' %}
                            <iframe src="{{ promoPlayer.src }}"
                                    title="{{ promo.sectionTitle|e('html_attr') }}"
                                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                                    allowfullscreen
                                    loading="lazy"
                                    class="w-100 h-100 rounded border-0"></iframe>
                        {% elseif promoPlayer.kind == 'direct' %}
                            <video controls playsinline preload="metadata" class="w-100 h-100 rounded bg-dark" style="object-fit: contain;" src="{{ promoPlayer.src }}"></video>
                        {% else %}
                            <iframe src="{{ promoPlayer.src }}"
                                    title="{{ promo.sectionTitle|e('html_attr') }}"
                                    allowfullscreen
                                    loading="lazy"
                                    class="w-100 h-100 rounded border-0"></iframe>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
        {% endif %}
    </div>

    {# Nos Services #}
    <div class="py-5" style="background: #f8f9fa;">
        <div class="container">
            <div class="text-center mb-5">
                <h2 class="display-5 fw-bold mb-3">Nos services</h2>
                <p class="lead text-muted">Un accompagnement complet pour votre développement</p>
            </div>

            <div class="row g-4">
                <div class="col-lg-4">
                    <div class="card shadow-sm border-0 p-4 h-100 feature-card">
                        <div class="text-center mb-3">
                            <i class="bi bi-person-check" style="font-size: 3rem; color: #667eea;"></i>
                        </div>
                        <h3 class="h5 text-center mb-3">Coaching Individualisé</h3>
                        <p class="text-muted text-center">Des séances personnalisées pour identifier et surmonter vos obstacles spécifiques.</p>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="card shadow-sm border-0 p-4 h-100 feature-card">
                        <div class="text-center mb-3">
                            <i class="bi bi-book" style="font-size: 3rem; color: #667eea;"></i>
                        </div>
                        <h3 class="h5 text-center mb-3">Formations Pratiques</h3>
                        <p class="text-muted text-center">Des programmes concrets et interactifs pour acquérir des compétences rapidement.</p>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="card shadow-sm border-0 p-4 h-100 feature-card">
                        <div class="text-center mb-3">
                            <i class="bi bi-graph-up-arrow" style="font-size: 3rem; color: #667eea;"></i>
                        </div>
                        <h3 class="h5 text-center mb-3">Objectifs Mesurables</h3>
                        <p class="text-muted text-center">Établissement d'objectifs clairs pour suivre vos progrès et célébrer vos réussites.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# À Propos #}
    <div class="container my-5 py-5">
        <div class="row align-items-center">
            <div class="col-lg-5 mb-4 mb-lg-0">
                <div class="text-center">
                    <div class="mb-4" style="width: 200px; height: 200px; margin: 0 auto; border-radius: 50%; overflow: hidden; box-shadow: 0 10px 40px rgba(102, 126, 234, 0.3); position: relative;">
                        {% set home_photo_style %}
                            width: 100%; height: 100%; object-fit: cover; object-position: {{ home.aboutImagePanX }}% {{ home.aboutImagePanY }}%; transform: scale({{ home.aboutImageZoom / 100 }}); transform-origin: center center;
                        {% endset %}
                        {% if home.hasUploadedAboutImage %}
                            <img src="{{ asset('uploads/homepage/' ~ home.aboutImageFilename) }}"
                                 alt="{{ home.aboutName }}"
                                 style="{{ home_photo_style|trim }}">
                        {% elseif home.aboutImageUrl|trim != '' %}
                            <img src="{{ home.aboutImageUrl }}"
                                 alt="{{ home.aboutName }}"
                                 style="{{ home_photo_style|trim }}">
                        {% else %}
                            <div style="width: 100%; height: 100%; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); display: flex; align-items: center; justify-content: center;">
                                <i class="bi bi-person-circle" style="font-size: 8rem; color: white;"></i>
                            </div>
                        {% endif %}
                    </div>
                    <h3 class="h4 fw-bold mb-2">{{ home.aboutName }}</h3>
                    <p class="text-muted">{{ home.aboutRole }}</p>
                </div>
            </div>
            <div class="col-lg-7">
                <h2 class="h1 fw-bold mb-4">{{ home.aboutHeading }}</h2>
                <div class="mb-3">{{ home.aboutParagraph1|raw }}</div>
                <div class="mb-4">{{ home.aboutParagraph2|raw }}</div>

                <div class="card shadow-sm border-0 p-4 mb-4" style="background: linear-gradient(135deg, #667eea15 0%, #764ba215 100%);">
                    <h4 class="h6 mb-3 fw-bold" style="color: #667eea;">{{ home.aboutListTitle }}</h4>
                    <ul class="list-unstyled mb-0">
                        {% for rawLine in home.aboutListItems|split('\n') %}
                            {% set line = rawLine|trim %}
                            {% if line %}
                                <li class="mb-2"><i class="bi bi-check-circle-fill me-2" style="color: #667eea;"></i> {{ line|e('html') }}</li>
                            {% endif %}
                        {% endfor %}
                    </ul>
                </div>

                <div class="d-flex gap-2 flex-wrap">
                    <span class="badge bg-primary p-2"><i class="bi bi-award"></i> {{ home.aboutBadge1 }}</span>
                    <span class="badge bg-primary p-2"><i class="bi bi-brain"></i> {{ home.aboutBadge2 }}</span>
                    <span class="badge bg-primary p-2"><i class="bi bi-lightbulb"></i> {{ home.aboutBadge3 }}</span>
                </div>
            </div>
        </div>
    </div>

    {# Contact #}
    <div class="py-5" id="contact" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
        <div class="container py-4">
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="text-center text-white mb-4">
                        <h2 class="display-5 fw-bold mb-3">Nous contacter</h2>
                        <p class="lead mb-0 opacity-90">Une question sur nos formations ? Écrivez-nous, nous vous répondrons dans les meilleurs délais.</p>
                    </div>

                    {% for flash_success in app.flashes('contact_success') %}
                        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                            <i class="bi bi-check-circle-fill me-2"></i>{{ flash_success }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
                        </div>
                    {% endfor %}
                    {% for flash_warning in app.flashes('contact_warning') %}
                        <div class="alert alert-warning alert-dismissible fade show shadow-sm" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>{{ flash_warning }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
                        </div>
                    {% endfor %}

                    <div class="card shadow-lg border-0">
                        <div class="card-body p-4 p-md-5">
                            {{ form_start(contactForm, { attr: { class: 'contact-form', novalidate: 'novalidate' } }) }}

                            {% if contactForm.vars.errors|length > 0 %}
                                <div class="alert alert-danger">
                                    {{ form_errors(contactForm) }}
                                </div>
                            {% endif %}

                            <div class="row g-4">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">
                                        <i class="bi bi-person text-primary me-2"></i>{{ form_label(contactForm.nom) }}
                                    </label>
                                    {{ form_widget(contactForm.nom, { attr: { class: 'form-control form-control-lg' } }) }}
                                    {{ form_errors(contactForm.nom) }}
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">
                                        <i class="bi bi-envelope text-primary me-2"></i>{{ form_label(contactForm.email) }}
                                    </label>
                                    {{ form_widget(contactForm.email, { attr: { class: 'form-control form-control-lg' } }) }}
                                    {{ form_errors(contactForm.email) }}
                                </div>
                                <div class="col-12">
                                    <label class="form-label fw-semibold">
                                        <i class="bi bi-telephone text-primary me-2"></i>{{ form_label(contactForm.telephone) }}
                                    </label>
                                    {{ form_widget(contactForm.telephone, { attr: { class: 'form-control form-control-lg' } }) }}
                                    {{ form_errors(contactForm.telephone) }}
                                </div>
                                <div class="col-12">
                                    <label class="form-label fw-semibold">
                                        <i class="bi bi-chat-left-text text-primary me-2"></i>{{ form_label(contactForm.message) }}
                                    </label>
                                    {{ form_widget(contactForm.message, { attr: { class: 'form-control form-control-lg' } }) }}
                                    {{ form_errors(contactForm.message) }}
                                </div>
                                <div class="col-12 d-grid">
                                    {{ form_widget(contactForm.submit, { attr: { class: 'btn btn-primary btn-lg cta-button' } }) }}
                                </div>
                            </div>

                            {{ form_end(contactForm) }}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

{% endblock %}
