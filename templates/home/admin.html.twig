{% extends 'base.admin.html.twig' %}

{% block title %}Panneau de configuration{% endblock %}

{% block body %}

    <h1>Panneau de configuration</h1>

    <p>Bienvenue dans le panneau de configuration des <strong>administrateurs</strong>. Vous pouvez gérer les catégories, formations, chapitres, la page d’accueil, le média promotionnel, les messages de contact, les <strong>paiements</strong> et les statistiques.</p>

    <div class="row g-3 mt-2">
        {% if is_granted('ROLE_SUPER_ADMIN') %}
        <div class="col-md-6 col-lg-4">
            <a href="{{ path('app_admin_home_page_edit') }}" class="card h-100 text-decoration-none text-dark border-0 shadow-sm">
                <div class="card-body">
                    <h2 class="h5"><i class="bi bi-house-door text-primary"></i> Page d’accueil</h2>
                    <p class="card-text text-muted small mb-0">Personnalisez toute la page d'accueil : bandeau, chiffres, mission, services, à propos et contact.</p>
                </div>
            </a>
        </div>
        <div class="col-md-6 col-lg-4">
            <a href="{{ path('app_admin_home_promo') }}" class="card h-100 text-decoration-none text-dark border-0 shadow-sm">
                <div class="card-body">
                    <h2 class="h5"><i class="bi bi-play-btn text-primary"></i> Média d’accueil</h2>
                    <p class="card-text text-muted small mb-0">Vidéo promotionnelle de la page d'accueil (fichier ou lien YouTube, Vimeo, etc.).</p>
                </div>
            </a>
        </div>
        <div class="col-md-6 col-lg-4">
            <a href="{{ path('app_admin_payments') }}" class="card h-100 text-decoration-none text-dark border-0 shadow-sm">
                <div class="card-body">
                    <h2 class="h5"><i class="bi bi-credit-card text-primary"></i> Paiements</h2>
                    <p class="card-text text-muted small mb-0">Historique des achats, chiffre d'affaires et paiements Stripe.</p>
                </div>
            </a>
        </div>
        <div class="col-md-6 col-lg-4">
            <a href="{{ path('app_admin_user_index') }}" class="card h-100 text-decoration-none text-dark border-0 shadow-sm">
                <div class="card-body">
                    <h2 class="h5"><i class="bi bi-person-gear text-primary"></i> Administrateurs</h2>
                    <p class="card-text text-muted small mb-0">Créer et gérer les comptes administrateurs de la plateforme.</p>
                </div>
            </a>
        </div>
        {% endif %}
        <div class="col-md-6 col-lg-4">
            <a href="{{ path('app_admin_contact_index') }}" class="card h-100 text-decoration-none text-dark border-0 shadow-sm">
                <div class="card-body">
                    <h2 class="h5"><i class="bi bi-envelope text-primary"></i> Messages de contact</h2>
                    <p class="card-text text-muted small mb-0">Consulter les demandes envoyées depuis le formulaire « Nous contacter ».</p>
                </div>
            </a>
        </div>
    </div>

{% endblock %}
