    <h2>Liste des chapitres</h2>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Titre</th>
                <th>Media</th>
                <th>Ordre</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for chapitre in formation.chapitres %}
            <tr>
                <td>{{ chapitre.id }}</td>
                <td>{{ chapitre.titre }}</td>
                <td>
                    {% set preview = mediaHelper is defined ? mediaHelper.resolve(chapitre) : null %}
                    {% if preview %}
                        {% if preview.kind == 'upload_image' %}
                            <img src="{{ asset(preview.src) }}" width="120" class="rounded" alt="">
                        {% else %}
                            <span class="badge bg-secondary"><i class="bi bi-play-circle"></i> Vidéo</span>
                        {% endif %}
                    {% else %}
                        <span class="text-muted">—</span>
                    {% endif %}
                </td>
                <td>{{ chapitre.ordre }}</td>
                <td>
                    <a class="btn btn-secondary" href="{{ path('app_admin_chapitre_edit', {'chapitre': chapitre.id}) }}">Modifier</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6">Aucun chapitre crée.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a class="btn btn-success" href="{{ path('app_admin_chapitre_new', {'formation':formation.id}) }}">Créer un nouveau chapitre</a>
