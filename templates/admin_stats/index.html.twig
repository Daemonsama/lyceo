{% extends 'base.admin.html.twig' %}

{% block title %}Tableau de bord — Statistiques{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/admin-dashboard.css') }}">
{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item active" aria-current="page">Statistiques</li>
{% endblock %}

{% block body %}
    {% set overview = dashboard.overview %}
    {% set payments = dashboard.payments %}

    <div class="admin-dashboard">
        <div class="container-fluid px-4">

            {# En-tête #}
            <div class="admin-dashboard-header">
                <div>
                    <h1 class="admin-dashboard-title">Tableau de bord</h1>
                    <p class="admin-dashboard-subtitle">Vue d'ensemble de la plateforme Lyceo Campus.</p>
                </div>
                <div class="admin-dashboard-actions">
<<<<<<<<< Temporary merge branch 1
                    <a href="{{ path('app_admin_payments') }}" class="btn btn-outline-dashboard">
                        <i class="bi bi-credit-card me-1"></i> Paiements
