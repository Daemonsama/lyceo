{% extends 'base.html.twig' %}

{% block title %}Créer un compte{% endblock %}

{% block body %}

    {# Bandeau d'en-tête #}
    <div class="auth-header-fullwidth">
        <div class="container">
            <div class="text-center">
                <h1 class="display-5 fw-bold mb-2">Créer un compte</h1>
                <p class="lead opacity-75">Rejoignez SPC Formation et accédez à nos formations</p>
            </div>
        </div>
    </div>

    <div class="container my-5">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">

                {# Messages d'erreur flash #}
                {% for flash_error in app.flashes('verify_email_error') %}
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        {{ flash_error }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}

                {# Carte du formulaire #}
                <div class="card auth-card shadow-sm border-0">
                    <div class="card-body p-4 p-md-5">

                        {# Erreurs globales du formulaire #}
                        {% if registrationForm.vars.errors|length > 0 %}
                            <div class="alert alert-danger">
                                {{ form_errors(registrationForm) }}
                            </div>
                        {% endif %}

                        {{ form_start(registrationForm) }}

                        {# Nom #}
                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                <i class="bi bi-person text-primary me-2"></i>Nom
                            </label>
                            {{ form_widget(registrationForm.nom, {
                                'attr': {
                                    'class': 'form-control form-control-lg',
                                    'placeholder': 'Votre nom'
                                }
                            }) }}
                            {{ form_errors(registrationForm.nom) }}
                        </div>

                        {# Prénom #}
                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                <i class="bi bi-person-badge text-primary me-2"></i>Prénom
                            </label>
                            {{ form_widget(registrationForm.prenom, {
                                'attr': {
                                    'class': 'form-control form-control-lg',
                                    'placeholder': 'Votre prénom'
                                }
                            }) }}
                            {{ form_errors(registrationForm.prenom) }}
                        </div>

                        {# Email #}
                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                <i class="bi bi-envelope text-primary me-2"></i>Adresse email
                            </label>
                            {{ form_widget(registrationForm.email, {
                                'attr': {
                                    'class': 'form-control form-control-lg',
                                    'placeholder': 'votre@email.com'
                                }
                            }) }}
                            {{ form_errors(registrationForm.email) }}
                        </div>

                        {# Mot de passe #}
                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                <i class="bi bi-lock text-primary me-2"></i>Mot de passe
                            </label>
                            <div class="password-field-wrap">
                                {{ form_widget(registrationForm.plainPassword, {
                                    'attr': {
                                        'class': 'form-control form-control-lg password-input',
                                        'placeholder': '••••••••'
                                    }
                                }) }}
                            </div>
                            {{ form_errors(registrationForm.plainPassword) }}
                            <small class="form-text text-muted">
                                <i class="bi bi-info-circle me-1"></i>
                                Minimum 8 caractères
                            </small>
                        </div>

                        {# Conditions d'utilisation #}
                        <div class="mb-4">
                            <div class="form-check">
                                {{ form_widget(registrationForm.agreeTerms, {
                                    'attr': {'class': 'form-check-input'}
                                }) }}
                                <label class="form-check-label">
                                    {{ form_label(registrationForm.agreeTerms) }}
                                </label>
                            </div>
                            {{ form_errors(registrationForm.agreeTerms) }}
                        </div>

                        {# Bouton de soumission #}
                        <div class="d-grid mb-4">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-person-plus-fill me-2"></i>Créer mon compte
                            </button>
                        </div>

                        {{ form_end(registrationForm) }}

                        {# Séparateur #}
                        <div class="text-center mb-3">
                            <hr class="my-4">
                        </div>

                        {# Lien vers login #}
                        <div class="text-center">
                            <p class="text-muted mb-0">
                                Vous avez déjà un compte ?
                                <a href="{{ path('app_login') }}" class="text-decoration-none fw-semibold">
                                    Se connecter
                                </a>
                            </p>
                        </div>

                    </div>
                </div>

            </div>
        </div>
    </div>

{% endblock %}
