{% extends 'base.html.twig' %}

{% block title %}Connexion - SPC Formation{% endblock %}

{% block body %}
    <div class="login-page">
        <div class="container">
            <div class="row justify-content-center align-items-center min-vh-100 py-5">
                <div class="col-12 col-md-10 col-lg-8">
                    <div class="row g-0 shadow-lg rounded-4 overflow-hidden">

                        {# PARTIE GAUCHE - FORMULAIRE #}
                        <div class="col-lg-6 bg-white p-5">
                            <div class="login-form-container">
                                {# LOGO ET TITRE #}
                                <div class="text-center mb-4">
                                    <div class="logo-icon mb-3">
                                        <img src="{{ asset('image/logo2-transparent.png') }}"
                                             alt="Logo Lyceo Campus"
                                             class="login-logo-img">
                                    </div>
                                    <h2 class="login-title">Bienvenue !</h2>
                                    <p class="text-muted">Connectez-vous à votre espace formation</p>
                                </div>

                                {# MESSAGES D'ERREUR #}
                                {% for message in app.flashes('success') %}
                                    <div class="alert alert-success alert-custom d-flex align-items-center" role="alert">
                                        <i class="bi bi-check-circle-fill me-2"></i>
                                        <div>{{ message }}</div>
                                    </div>
                                {% endfor %}

                                {% if error %}
                                    <div class="alert alert-danger alert-custom d-flex align-items-center" role="alert">
                                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                        <div>{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                                    </div>
                                {% endif %}

                                {# SI DÉJÀ CONNECTÉ #}
                                {% if app.user %}
                                    <div class="alert alert-info alert-custom d-flex align-items-center" role="alert">
                                        <i class="bi bi-info-circle-fill me-2"></i>
                                        <div>
                                            Vous êtes connecté en tant que <strong>{{ app.user.userIdentifier }}</strong>
                                            <a href="{{ path('app_logout') }}" class="alert-link ms-2">Se déconnecter</a>
                                        </div>
                                    </div>
                                {% endif %}

                                {# FORMULAIRE DE CONNEXION #}
                                <form method="post" class="login-form">
                                    {# EMAIL #}
                                    <div class="form-floating mb-3">
                                        <input type="email"
                                               value="{{ last_username }}"
                                               name="_username"
                                               id="username"
                                               class="form-control form-control-custom"
                                               placeholder="votre@email.com"
                                               autocomplete="email"
                                               required
                                               autofocus>
                                        <label for="username">
                                            <i class="bi bi-envelope me-2"></i>Adresse email
                                        </label>
                                    </div>

                                    {# MOT DE PASSE #}
                                    <div class="form-floating mb-3 password-field-wrap">
                                        <input type="password"
                                               name="_password"
                                               id="password"
                                               class="form-control form-control-custom password-input"
                                               placeholder="Mot de passe"
                                               autocomplete="current-password"
                                               required>
                                        <label for="password">
                                            <i class="bi bi-lock me-2"></i>Mot de passe
                                        </label>
                                    </div>

                                    {# REMEMBER ME #}
                                    <div class="form-check mb-4">
                                        <input class="form-check-input"
                                               type="checkbox"
                                               name="_remember_me"
                                               id="_remember_me">
                                        <label class="form-check-label" for="_remember_me">
                                            Se souvenir de moi
                                        </label>
                                    </div>

                                    {# TOKEN CSRF #}
                                    <input type="hidden"
                                           name="_csrf_token"
                                           value="{{ csrf_token('authenticate') }}">

                                    {# BOUTON CONNEXION #}
                                    <button class="btn btn-login w-100 py-3 mb-3" type="submit">
                                        <i class="bi bi-box-arrow-in-right me-2"></i>
                                        Se connecter
                                    </button>

                                    {# LIEN MOT DE PASSE OUBLIÉ #}
                                    <div class="text-center mb-3">
                                        <a href="{{ path('app_forgot_password_request') }}" class="text-muted text-decoration-none forgot-password">
                                            <small>Mot de passe oublié ?</small>
                                        </a>
                                    </div>

                                    {# SÉPARATEUR #}
                                    <div class="divider my-4">
                                        <span class="divider-text">OU</span>
                                    </div>

                                    {# BOUTON INSCRIPTION #}
                                    <a href="{{ path('app_register') }}" class="btn btn-register w-100 py-3">
                                        <i class="bi bi-person-plus me-2"></i>
                                        Créer un compte
                                    </a>
                                </form>
                            </div>
                        </div>

                        {# PARTIE DROITE - INFORMATIONS #}
                        <div class="col-lg-6 login-info-side d-none d-lg-flex">
                            <div class="login-info-content">
                                <div class="info-icon mb-4">
                                    <i class="bi bi-rocket-takeoff"></i>
                                </div>
                                <h3 class="text-white fw-bold mb-4">Développez vos compétences</h3>
                                <p class="text-white-50 mb-4">
                                    Accédez à des formations de qualité pour booster votre carrière professionnelle.
                                </p>

                                <div class="features-list">
                                    <div class="feature-item mb-3">
                                        <i class="bi bi-check-circle-fill text-success me-2"></i>
                                        <span class="text-white">Formateur experimenté</span>
                                    </div>
                                    <div class="feature-item">
                                        <i class="bi bi-check-circle-fill text-success me-2"></i>
                                        <span class="text-white">Accès 24/7</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
