{% extends 'base.admin.html.twig' %}

{% block title %}Messages de contact{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item active" aria-current="page">Messages de contact</li>
{% endblock %}

{% block body %}
    <div class="container py-4">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
            <div>
                <h1 class="h2 mb-1"><i class="bi bi-envelope text-primary"></i> Messages de contact</h1>
                <p class="text-muted mb-0">Messages reçus via le formulaire de la page d'accueil.</p>
            </div>
            <a href="{{ path('app_admin') }}" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Retour au panneau
            </a>
        </div>

        <div class="card shadow-sm border-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Date</th>
                            <th>Nom</th>
                            <th>E-mail</th>
                            <th>Téléphone</th>
                            <th>Message</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for msg in messages %}
                        <tr>
                            <td class="text-nowrap small">{{ msg.createdAt|date('d/m/Y H:i') }}</td>
                            <td>{{ msg.nom }}</td>
                            <td><a href="mailto:{{ msg.email }}">{{ msg.email }}</a></td>
                            <td class="text-nowrap">{{ msg.telephone }}</td>
                            <td class="text-muted small" style="max-width: 280px;">
                                {{ msg.message|length > 80 ? msg.message|slice(0, 80) ~ '…' : msg.message }}
                            </td>
                            <td class="text-end text-nowrap">
                                <a href="{{ path('app_admin_contact_show', { id: msg.id }) }}" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye"></i> Lire
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="text-center text-muted py-5">
                                <i class="bi bi-inbox display-6 d-block mb-2"></i>
                                Aucun message pour le moment.
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
