{% extends 'base.admin.html.twig' %}

{% block title %}Catégories{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item active" aria-current="page">Catégories</li>
{% endblock %}

{% block body %}
    <div class="container py-4">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
            <div>
                <h1 class="h3 mb-1"><i class="bi bi-tags text-primary"></i> Catégories</h1>
                <p class="text-muted mb-0">Organisez le catalogue de formations par thématique.</p>
            </div>
            <a href="{{ path('app_categorie_new') }}" class="btn btn-admin-primary">
                <i class="bi bi-plus-lg me-1"></i> Nouvelle catégorie
            </a>
        </div>

        <div class="card border-0 shadow-sm admin-user-card">
            <div class="card-body p-0">
                {% if categories is not empty %}
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0 admin-user-table">
                            <thead>
                                <tr>
                                    <th>Catégorie</th>
                                    <th>Formations</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                            {% for categorie in categories %}
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            {% include 'categorie/_thumb.html.twig' with { visual: categorie_visual(categorie), uid: categorie.id } %}
                                            <div>
                                                <strong>{{ categorie.nom }}</strong>
                                                <div class="small text-muted">#{{ categorie.id }}</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        {% set count = categorie.formations|length %}
                                        <span class="badge bg-admin-standard">{{ count }} formation{{ count > 1 ? 's' : '' }}</span>
                                    </td>
                                    <td class="text-end">
                                        <div class="d-inline-flex flex-wrap gap-2 justify-content-end">
                                            <a href="{{ path('app_categorie_show', { id: categorie.id }) }}"
                                               class="btn btn-sm btn-admin-outline">
                                                <i class="bi bi-eye"></i> Voir
                                            </a>
                                            <a href="{{ path('app_categorie_edit', { id: categorie.id }) }}"
                                               class="btn btn-sm btn-admin-primary">
                                                <i class="bi bi-pencil"></i> Modifier
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <div class="text-center text-muted py-5">
                        <i class="bi bi-tags fs-2 d-block mb-2"></i>
                        Aucune catégorie créée.
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}
