<form method="post" action="{{ path('app_categorie_delete', {'id': categorie.id}) }}" onsubmit="return confirm('Supprimer cette catégorie ?{% if categorie.formations|length > 0 %}\n\nAttention : {{ categorie.formations|length }} module(s) lié(s) seront aussi supprimé(s).{% endif %}');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ categorie.id) }}">
    <button class="btn btn-danger">Supprimer</button>
</form>
