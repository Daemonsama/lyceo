{# Visuel catégorie (SVG) — slug : management, coaching, leadership, communication, formation #}
{% set slug = visual.slug|default('formation') %}
{% set uid = uid|default('0') %}
<span class="admin-categorie-thumb admin-categorie-thumb--{{ slug }}" role="img" aria-label="{{ visual.label|default('Catégorie') }}">
    <svg viewBox="0 0 48 48" width="48" height="48" aria-hidden="true" focusable="false">
        <defs>
            <linearGradient id="cat-grad-management-{{ uid }}" x1="4" y1="4" x2="44" y2="44" gradientUnits="userSpaceOnUse">
                <stop stop-color="#9e95f5"/><stop offset="1" stop-color="#7367f0"/>
            </linearGradient>
            <linearGradient id="cat-grad-coaching-{{ uid }}" x1="4" y1="4" x2="44" y2="44" gradientUnits="userSpaceOnUse">
                <stop stop-color="#5ce4f7"/><stop offset="1" stop-color="#00cfe8"/>
            </linearGradient>
            <linearGradient id="cat-grad-leadership-{{ uid }}" x1="4" y1="4" x2="44" y2="44" gradientUnits="userSpaceOnUse">
                <stop stop-color="#ffb976"/><stop offset="1" stop-color="#ff9f43"/>
            </linearGradient>
            <linearGradient id="cat-grad-communication-{{ uid }}" x1="4" y1="4" x2="44" y2="44" gradientUnits="userSpaceOnUse">
                <stop stop-color="#f093b0"/><stop offset="1" stop-color="#ea5480"/>
            </linearGradient>
            <linearGradient id="cat-grad-formation-{{ uid }}" x1="4" y1="4" x2="44" y2="44" gradientUnits="userSpaceOnUse">
                <stop stop-color="#9e95f5"/><stop offset="1" stop-color="#667eea"/>
            </linearGradient>
            <linearGradient id="cat-grad-marketing-{{ uid }}" x1="4" y1="4" x2="44" y2="44" gradientUnits="userSpaceOnUse">
                <stop stop-color="#ff9f43"/><stop offset="1" stop-color="#ff6b6b"/>
            </linearGradient>
            <linearGradient id="cat-grad-rh-{{ uid }}" x1="4" y1="4" x2="44" y2="44" gradientUnits="userSpaceOnUse">
                <stop stop-color="#667eea"/><stop offset="1" stop-color="#764ba2"/>
            </linearGradient>
            <linearGradient id="cat-grad-finance-{{ uid }}" x1="4" y1="4" x2="44" y2="44" gradientUnits="userSpaceOnUse">
                <stop stop-color="#69db7c"/><stop offset="1" stop-color="#28a745"/>
            </linearGradient>
        </defs>
        {% if slug == 'management' %}
            <rect x="4" y="4" width="40" height="40" rx="12" fill="url(#cat-grad-management-{{ uid }})"/>
            <rect x="18" y="11" width="12" height="8" rx="3" fill="#fff" opacity="0.95"/>
            <rect x="10" y="27" width="10" height="8" rx="2.5" fill="#fff" opacity="0.88"/>
            <rect x="28" y="27" width="10" height="8" rx="2.5" fill="#fff" opacity="0.88"/>
            <path d="M24 19v5M19 24h10" stroke="#fff" stroke-width="2" stroke-linecap="round"/>
        {% elseif slug == 'coaching' %}
            <rect x="4" y="4" width="40" height="40" rx="12" fill="url(#cat-grad-coaching-{{ uid }})"/>
            <circle cx="24" cy="18" r="6" fill="#fff" opacity="0.95"/>
            <path d="M12 36c2.5-6 7-9 12-9s9.5 3 12 9" fill="#fff" opacity="0.9"/>
            <path d="M31 16l2 2 4-4" stroke="#00a3b4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        {% elseif slug == 'leadership' %}
            <rect x="4" y="4" width="40" height="40" rx="12" fill="url(#cat-grad-leadership-{{ uid }})"/>
            <path d="M24 12l2.6 6.8H34l-5.5 4.1 2.1 6.8L24 25.6l-6.6 4.1 2.1-6.8L14 18.8h7.4L24 12z" fill="#fff" opacity="0.95"/>
        {% elseif slug == 'communication' %}
            <rect x="4" y="4" width="40" height="40" rx="12" fill="url(#cat-grad-communication-{{ uid }})"/>
            <path d="M14 16h20a3 3 0 0 1 3 3v8a3 3 0 0 1-3 3H22l-6 5v-5h-2a3 3 0 0 1-3-3v-8a3 3 0 0 1 3-3z" fill="#fff" opacity="0.92"/>
            <circle cx="19" cy="23" r="1.5" fill="#ea5480"/>
            <circle cx="24" cy="23" r="1.5" fill="#ea5480"/>
            <circle cx="29" cy="23" r="1.5" fill="#ea5480"/>
        {% elseif slug == 'marketing' %}
            <rect x="4" y="4" width="40" height="40" rx="12" fill="url(#cat-grad-marketing-{{ uid }})"/>
            <path d="M14 32V22l10-6 10 6v10" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M20 32v-8h8v8" fill="#fff" opacity="0.9"/>
        {% elseif slug == 'rh' %}
            <rect x="4" y="4" width="40" height="40" rx="12" fill="url(#cat-grad-rh-{{ uid }})"/>
            <circle cx="18" cy="20" r="4" fill="#fff" opacity="0.95"/>
            <circle cx="30" cy="20" r="4" fill="#fff" opacity="0.85"/>
            <path d="M11 34c1.8-4 4.8-6 7-6s5.2 2 7 6" fill="#fff" opacity="0.88"/>
            <path d="M25 34c1.2-3 3.2-4.5 5-4.5s3.8 1.5 5 4.5" fill="#fff" opacity="0.78"/>
        {% elseif slug == 'finance' %}
            <rect x="4" y="4" width="40" height="40" rx="12" fill="url(#cat-grad-finance-{{ uid }})"/>
            <rect x="13" y="14" width="22" height="20" rx="3" fill="#fff" opacity="0.92"/>
            <path d="M17 24h14M17 28h10" stroke="#28a745" stroke-width="2" stroke-linecap="round"/>
            <path d="M24 18v12" stroke="#28a745" stroke-width="2" stroke-linecap="round"/>
        {% else %}
            <rect x="4" y="4" width="40" height="40" rx="12" fill="url(#cat-grad-formation-{{ uid }})"/>
            <path d="M14 16h20v18H14z" fill="#fff" opacity="0.92"/>
            <path d="M18 14h12a2 2 0 0 1 2 2v2H16v-2a2 2 0 0 1 2-2z" fill="#fff" opacity="0.95"/>
            <path d="M20 24h8M20 28h5" stroke="#7367f0" stroke-width="2" stroke-linecap="round"/>
        {% endif %}
    </svg>
</span>
