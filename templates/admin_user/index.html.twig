{% extends 'base.admin.html.twig' %}

{% block title %}Administrateurs{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item active" aria-current="page">Administrateurs</li>
{% endblock %}

{% block body %}
    <div class="container py-4">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
            <div>
                <h1 class="h3 mb-1"><i class="bi bi-people-fill text-primary"></i> Administrateurs</h1>
                <p class="text-muted mb-0">Comptes avec accès au panneau d'administration Lyceo Campus.</p>
            </div>
            <a href="{{ path('app_admin_user_new') }}" class="btn btn-admin-primary">
                <i class="bi bi-person-plus me-1"></i> Nouvel administrateur
            </a>
        </div>

        <div class="card border-0 shadow-sm admin-user-card">
            <div class="card-body p-0">
                {% if users is not empty %}
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0 admin-user-table">
                            <thead>
                                <tr>
                                    <th>Administrateur</th>
                                    <th>E-mail</th>
                                    <th>Rôle</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                            {% for user in users %}
                                <tr>
                                    <td>
                                        <strong>{{ user.prenom }} {{ user.nom }}</strong>
                                    </td>
                                    <td>{{ user.email }}</td>
                                    <td>
                                        <span class="badge {{ user.superAdmin ? 'bg-admin-super' : 'bg-admin-standard' }}">
                                            {{ user.adminRoleLabel }}
                                        </span>
                                    </td>
                                    <td class="text-end">
                                        <div class="d-inline-flex flex-wrap gap-2 justify-content-end">
                                            <a href="{{ path('app_admin_user_show', { id: user.id }) }}"
                                               class="btn btn-sm btn-admin-outline">
                                                <i class="bi bi-eye"></i> Voir
                                            </a>
                                            <a href="{{ path('app_admin_user_edit', { id: user.id }) }}"
                                               class="btn btn-sm btn-admin-primary">
                                                <i class="bi bi-pencil"></i> Modifier
                                            </a>
                                            {% if user.id != app.user.id %}
                                                {{ include('admin_user/_delete_form.html.twig', { compact: true }) }}
                                            {% endif %}
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <div class="text-center text-muted py-5">
                        <i class="bi bi-person-x fs-2 d-block mb-2"></i>
                        Aucun administrateur enregistré.
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}
