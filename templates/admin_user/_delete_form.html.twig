<form method="post"
      action="{{ path('app_admin_user_delete', { id: user.id }) }}"
      class="d-inline"
      onsubmit="return confirm('Supprimer ce compte administrateur ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
    <button class="btn btn-sm {{ compact|default(false) ? 'btn-admin-danger' : 'btn-admin-danger' }}">
        <i class="bi bi-trash"></i>{{ compact|default(false) ? '' : ' Supprimer' }}
    </button>
</form>
