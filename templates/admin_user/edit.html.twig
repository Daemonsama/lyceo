{% extends 'base.admin.html.twig' %}

{% block title %}Modifier {{ user.prenom }} {{ user.nom }}{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item"><a href="{{ path('app_admin_user_index') }}">Administrateurs</a></li>
    <li class="breadcrumb-item active" aria-current="page">Modifier</li>
{% endblock %}

{% block body %}
    <div class="container py-4">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm admin-user-card">
                    <div class="card-body p-4">
                        <h1 class="h4 mb-1">Modifier l'administrateur</h1>
                        <p class="text-muted mb-4">{{ user.email }} — {{ user.adminRoleLabel }}</p>
                        {{ include('admin_user/_form.html.twig', { button_label: 'Mettre à jour' }) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
