{% extends 'base.admin.html.twig' %}

{% block title %}{{ user.prenom }} {{ user.nom }}{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item"><a href="{{ path('app_admin_user_index') }}">Administrateurs</a></li>
    <li class="breadcrumb-item active" aria-current="page">{{ user.prenom }} {{ user.nom }}</li>
{% endblock %}

{% block body %}
    <div class="container py-4">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm admin-user-card">
                    <div class="card-body p-4">
                        <h1 class="h4 mb-3">{{ user.prenom }} {{ user.nom }}</h1>
                        <dl class="row mb-0">
                            <dt class="col-sm-4 text-muted">E-mail</dt>
                            <dd class="col-sm-8">{{ user.email }}</dd>
                            <dt class="col-sm-4 text-muted">Rôle</dt>
                            <dd class="col-sm-8">
                                <span class="badge {{ user.superAdmin ? 'bg-admin-super' : 'bg-admin-standard' }}">
                                    {{ user.adminRoleLabel }}
                                </span>
                            </dd>
                            <dt class="col-sm-4 text-muted">Compte vérifié</dt>
                            <dd class="col-sm-8">{{ user.verified ? 'Oui' : 'Non' }}</dd>
                        </dl>
                        <div class="d-flex flex-wrap gap-2 mt-4">
                            <a href="{{ path('app_admin_user_edit', { id: user.id }) }}" class="btn btn-admin-primary">
                                <i class="bi bi-pencil me-1"></i> Modifier
                            </a>
                            <a href="{{ path('app_admin_user_index') }}" class="btn btn-admin-outline">Retour à la liste</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
